# Delta credentials — copy to .env (never committed).

# Model access. Any OpenAI-compatible endpoint works; OpenRouter is the easy default.
# Get a key at https://openrouter.ai/keys and cap its spend there.
OPENROUTER_API_KEY=

# Exa — powers the built-in `web_search` tool. Optional; omit to disable web search.
# Get a key at https://exa.ai.
EXA_API_KEY=

# Pick the model the agent runs on (any slug your endpoint serves). Examples:
#   DELTA_MODEL_PRIMARY=anthropic/claude-sonnet-5
#   DELTA_MODEL_PRIMARY=openai/gpt-5.1
# Defaults to a sensible model if unset — see the guide at https://deltaharness.dev.
# DELTA_MODEL_PRIMARY=anthropic/claude-sonnet-5
